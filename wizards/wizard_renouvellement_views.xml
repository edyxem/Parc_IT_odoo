<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wizard_renouvellement_form" model="ir.ui.view">
            <field name="name">wizard.renouvellement.form</field>
            <field name="model">wizard.renouvellement</field>
            <field name="arch" type="xml">
                <form string="Renouveler le contrat">
                    <sheet>
                        <group string="Contrat actuel (référence)">
                            <field name="contrat_id" readonly="1"/>
                            <field name="fournisseur_id" readonly="1"/>
                            <field name="date_fin_actuelle" readonly="1"
                                   string="Date de fin actuelle"/>
                            <field name="montant_actuel" readonly="1"
                                   string="Montant actuel (FCFA)"/>
                        </group>

                        <group>
                            <group string="Nouveau contrat">
                                <field name="nouvelle_date_debut"/>
                                <field name="nouvelle_date_fin"/>
                                <field name="duree_mois" readonly="1"
                                       string="Durée calculée (mois)"/>
                                <field name="nouveau_montant"
                                       string="Nouveau montant (FCFA)"/>
                            </group>
                            <group string="Options">
                                <field name="copier_equipements"/>
                            </group>
                        </group>

                        <group string="Notes de renouvellement">
                            <field name="notes" nolabel="1"
                                   placeholder="Conditions de renouvellement, négociations…"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirmer"
                                string="Confirmer le renouvellement"
                                type="object"
                                class="btn-primary"/>
                        <button string="Annuler"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
